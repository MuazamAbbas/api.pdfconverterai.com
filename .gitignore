# Virtual environments
.venv/
venv/
env/
ENV/

# Python bytecode / cache
__pycache__/
*.pyc
*.pyo
*.pyd

# Environment / secrets - never commit
.env
.env.*
!.env.example

# Application logs (rotated separately, not source-controlled)
logs/
*.log

# Build artifacts
build/
dist/
*.egg-info/

# Downloaded/cached ML model weights (large binary data, not source code)
models/

# ACME challenge files (ephemeral, regenerated by CloudPanel/Let's Encrypt)
.well-known/

# OS/editor cruft
.DS_Store
